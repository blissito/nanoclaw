#!/usr/bin/env bash
# generate-image: call OpenAI image API
# Usage:
#   generate-image "prompt"                                    # text-to-image
#   generate-image "prompt" /path/to/img1.png                  # edit with 1 image
#   generate-image "prompt" /path/to/img1.png /path/to/img2.png  # edit with multiple images
set -euo pipefail

PROMPT="${1:?Usage: generate-image \"prompt\" [source-image ...]}"
shift
SOURCE_IMAGES=("$@")
OUTPUT_DIR="/workspace/group"
OUTPUT_FILE="${OUTPUT_DIR}/generated-$(date +%s%3N).png"

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  echo "ERROR: OPENAI_API_KEY not set" >&2
  exit 1
fi

if [[ ${#SOURCE_IMAGES[@]} -gt 0 ]]; then
  # Image editing via gpt-image-1 (supports multiple images)
  CURL_ARGS=(-sS -X POST "https://api.openai.com/v1/images/edits"
    -H "Authorization: Bearer $OPENAI_API_KEY"
    -F "model=gpt-image-1"
    -F "prompt=${PROMPT}")
  for img in "${SOURCE_IMAGES[@]}"; do
    CURL_ARGS+=(-F "image[]=@${img}")
  done
  RESPONSE=$(curl "${CURL_ARGS[@]}")
else
  # Text-to-image via gpt-image-1
  PAYLOAD=$(python3 -c "
import json, sys
print(json.dumps({
    'model': 'gpt-image-1',
    'prompt': sys.argv[1]
}))
" "$PROMPT")

  RESPONSE=$(curl -sS -X POST "https://api.openai.com/v1/images/generations" \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$PAYLOAD")
fi

# Check for API error
ERROR=$(python3 -c "
import json, sys
d = json.load(sys.stdin)
e = d.get('error', {})
if isinstance(e, dict) and e.get('message'):
    print(e['message'])
" <<< "$RESPONSE" 2>/dev/null || true)

if [[ -n "$ERROR" ]]; then
  echo "ERROR: OpenAI API: $ERROR" >&2
  exit 1
fi

# Decode base64 and save
python3 -c "
import json, sys, base64
d = json.load(sys.stdin)
b64 = d['data'][0]['b64_json']
with open(sys.argv[1], 'wb') as f:
    f.write(base64.b64decode(b64))
" "$OUTPUT_FILE" <<< "$RESPONSE"

# Track generation via IPC (non-fatal)
{
  GEN_TYPE="text2img"
  [[ ${#SOURCE_IMAGES[@]} -gt 0 ]] && GEN_TYPE="edit"
  IPC_DIR="/workspace/ipc/messages"
  mkdir -p "$IPC_DIR"
  TRACK_FILE="${IPC_DIR}/imgtrack-$(date +%s%3N).json"
  python3 -c "
import json, sys
json.dump({
    'type': 'track_image_gen',
    'gen_type': sys.argv[1],
    'prompt': sys.argv[2],
    'model': 'gpt-image-1',
    'cost_usd': 0.08
}, open(sys.argv[3], 'w'))
" "$GEN_TYPE" "$PROMPT" "$TRACK_FILE"
} || true

echo "$OUTPUT_FILE"
