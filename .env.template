# NanoClaw Environment Configuration
# Copy to .env and fill in your values.
# Lines starting with # are optional — uncomment if needed.

# --- Required ---
ANTHROPIC_API_KEY=
ASSISTANT_NAME=Andy

# --- Recommended ---
# OAuth token from Claude Max plan (preferred, no cost per message):
#CLAUDE_CODE_OAUTH_TOKEN=
# Phone number for WhatsApp pairing (with country code, no spaces/dashes):
#WHATSAPP_PHONE_NUMBER=
# DigitalOcean API token (for snapshot/droplet automation):
#DIGITALOCEAN_ACCESS_TOKEN=
# EasyBits (file/image/document storage MCP):
#EASYBITS_API_KEY=
# BrightData (web scraping/search MCP):
#BRIGHTDATA_API_TOKEN=
# OpenAI (Whisper fallback, misc):
#OPENAI_API_KEY=

# --- Channels (uncomment as needed) ---
#TELEGRAM_BOT_TOKEN=
#WEBHOOK_CHANNEL_PORT=3939
#WEBHOOK_CHANNEL_SECRET=
#WEBHOOK_CALLBACK_URL=
#FORMMY_CHANNEL_PORT=3940
#FORMMY_CHANNEL_SECRET=
#FORMMY_CALLBACK_URL=
#FORMMY_INTEGRATION_ID=
#FORMMY_DEFAULT_GROUP=

# --- MCP Server Keys (uncomment if enabling the server) ---
#PANEL_API_KEY=
#PANEL_URL=
#SMATCH_MONGODB_URI=
#SMATCH_CLUB_ID=
#KOMMO_BASE_URL=https://<subdomain>.kommo.com
#KOMMO_ACCESS_TOKEN=

# --- Integrations (uncomment as needed) ---
#FAL_KEY=
#GITHUB_GIST_TOKEN=
#ELEVENLABS_API_KEY=

# --- MercadoPago ---
#MP_ACCESS_TOKEN=
#MP_CLIENT_ID=
#MP_CLIENT_SECRET=
#MP_PUBLIC_KEY=
#MP_WEBHOOK_SECRET=

# --- AWS (for SES email, voice calls) ---
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_REGION=
#SES_FROM_EMAIL=
#SES_FROM_NAME=

# --- AWS Bedrock (for Claude via Bedrock) ---
#AWS_BEDROCK_ACCESS_KEY_ID=
#AWS_BEDROCK_SECRET_ACCESS_KEY=
#AWS_BEDROCK_REGION=

# --- Whisper (local transcription) ---
